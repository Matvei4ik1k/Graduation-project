<Window x:Class="Graduation_project.View.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Graduation_project.View.Windows"
        mc:Ignorable="d"
         MinHeight="900" MinWidth="1600" Width="1920" Height="1080" Title="MainWindow" WindowStartupLocation="CenterScreen" WindowState="Maximized" ResizeMode="NoResize">

    <Grid Background="#EFEFEF">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="370"/>
            <RowDefinition Height="115"/>
        </Grid.RowDefinitions>

        <!--Header-->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="1"/>

            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="0.1*"/>
                <ColumnDefinition Width="0.1*"/>
                <ColumnDefinition Width="0.1*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="2" Foreground="Black" Grid.Row="2" Content="CodeCraft" FontSize="30" FontWeight="Bold"/>
            <Button Grid.Column="4" Grid.Row="2" Foreground="Black" x:Name="HomeBtn" Content="Главная" FontSize="24"/>
            <Rectangle Grid.Column="4" Grid.Row="3" Fill="Black" Width="94"/>
            <Button Grid.Column="6" Grid.Row="2" Foreground="Black" x:Name="TheoryBtn" Content="Теория" FontSize="24" Click="TheoryBtn_Click"/>
            <Button Grid.Column="8" Grid.Row="2" Foreground="Black" x:Name="CourceBtn" Content="Курсы" FontSize="24" Click="CourceBtn_Click"/>
            <Button Grid.Column="10" Grid.Row="2" Foreground="Black" x:Name="SandboxBtn" Content="Песочница" FontSize="24" Click="SandboxBtn_Click"/>
            <Button Grid.Column="12" Grid.Row="2" Foreground="Black" x:Name="ProgressBtn" Content="Прогресс" FontSize="24" Click="ProgressBtn_Click"/>
            <Button Grid.Column="14" Grid.Row="2" Foreground="Black" x:Name="SettingsBtn" Content="Настройки" FontSize="24" Click="SettingsBtn_Click"/>
            <Rectangle Grid.Column="4" Grid.ColumnSpan="11" Grid.Row="5" Fill="Black" Width="1200"/>
            <Button FontSize="24"  Foreground="Black" Grid.Column="17" Grid.Row="2" Content="Matvei4ik"/>
            <Button FontSize="24"  Foreground="Black" Grid.Column="18" Grid.Row="2" Content="RU"/>
        </Grid>

        <!--Body-->
        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="55"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="418"/>
                <RowDefinition Height="115"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="614"/>
                <ColumnDefinition Width="276"/>
                <ColumnDefinition Width="141"/>
                <ColumnDefinition Width="276"/>
                <ColumnDefinition Width="613"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.ColumnSpan="5" Grid.Row="2" HorizontalAlignment="Center" FontSize="50">
            <Run Foreground="Black" Text="Изучайте код"/>
            <Run Foreground="#FFA83E" Text="быстрее"/>
            <Run Foreground="Black" Text="и"/>
            <Run Foreground="#2563EB" Text="эффективнее"/>
            </TextBlock>

            <TextBlock  Grid.ColumnSpan="5" TextAlignment="Center" Foreground="#6B7280" TextWrapping="Wrap" Grid.Row="4" FontSize="20" Width="690" Text="Интерактивное обучение, мгновенная визуализация кода. Изучайте HTML, CSS и современные веб-технологии прямо в приложении"/>

            <Border Grid.Column="1" Grid.Row="6" Background="#2563EB" CornerRadius="12" Width="275" >
                <Button FontSize="24" Content="Начать обучение" x:Name="StartLearning" Width="275"/>
            </Border>

            <Border Grid.Column="3" HorizontalAlignment="Left" Grid.Row="6" Background="#FFA83E" CornerRadius="12" Width="275" >
                <Button FontSize="24" Content="О курсах" Width="275"/>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="415"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="242"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="242"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <Border  Grid.ColumnSpan="7" Grid.RowSpan="2" Grid.Column="1" Grid.Row="2" Background="White" CornerRadius="20" Width="1240"/>
            <TextBlock Grid.Row="3" Grid.Column="2" FontSize="16"  Text="Активных пользователей" Foreground="#6B7280"/>
            <TextBlock Grid.Row="3" Grid.Column="4" FontSize="16"  Text="Уроков пройдено" Foreground="#6B7280"/>
            <TextBlock Grid.Row="3" Grid.Column="6" FontSize="16"  Text="Зарегестрировано пользователей" Foreground="#6B7280"/>

           
        </Grid>

        <Grid  Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="65"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="490"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="347"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="388"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="4" Grid.Column="4" FontSize="16" Foreground="Black" Text="13,203"/>
            <TextBlock Grid.Row="4" Grid.Column="8" FontSize="16" Foreground="Black" Text="33,512"/>
            <TextBlock Grid.Row="4" Grid.Column="12" FontSize="16" Foreground="Black" Text="341,970"/>

        </Grid>
    </Grid>
</Window>
