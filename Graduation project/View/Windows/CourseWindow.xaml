<Window x:Class="Graduation_project.View.Windows.CourseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Graduation_project.View.Windows"
        mc:Ignorable="d" MinHeight="900" MinWidth="1600" Width="1920" Height="1350" Title="CourceWindow" WindowStartupLocation="CenterScreen" WindowState="Maximized" ResizeMode="NoResize">
    <Grid Background="#EFEFEF">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!--Header-->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="1"/>

            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="215*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="108*"/>
                <ColumnDefinition Width="114*"/>
                <ColumnDefinition Width="108*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="2" Foreground="Black" Grid.Row="2" Content="CodeCraft" FontSize="30" FontWeight="Bold"/>
            <Button Grid.Column="4" Grid.Row="2" Foreground="Black" x:Name="HomeBtn" Content="Главная" FontSize="24" Click="HomeBtn_Click"/>
            <Button Grid.Column="6" Grid.Row="2" Foreground="Black" x:Name="TheoryBtn" Content="Теория" FontSize="24" Click="TheoryBtn_Click"/>
            <Button Grid.Column="8" Grid.Row="2" Foreground="Black" x:Name="CourceBtn" Content="Курсы" FontSize="24"/>
            <Rectangle Grid.Column="8" Grid.Row="3" Fill="Black" Width="78"/>
            <Button Grid.Column="10" Grid.Row="2" Foreground="Black" x:Name="SandboxBtn" Content="Песочница" FontSize="24" Click="SandboxBtn_Click"/>
            <Button Grid.Column="12" Grid.Row="2" Foreground="Black" x:Name="ProgressBtn" Content="Прогресс" FontSize="24" Click="ProgressBtn_Click"/>
            <Button Grid.Column="14" Grid.Row="2" Foreground="Black" x:Name="SettingsBtn" Content="Настройки" FontSize="24" Click="SettingsBtn_Click"/>
            <Rectangle Grid.Column="4" Grid.ColumnSpan="11" Grid.Row="5" Fill="Black" Width="1200"/>
            <Button FontSize="24"  Foreground="Black" Grid.Column="17" Grid.Row="2" Content="Matvei4ik"/>
            <Button FontSize="24"  Foreground="Black" Grid.Column="18" Grid.Row="2" Content="RU"/>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="55"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="23"/>
                <RowDefinition Height="33"/>
                <RowDefinition Height="23"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="781"/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="63"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="263"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>



            <Border Grid.Row="2" Grid.Column="10" Grid.ColumnSpan="3" Padding="34 8 10 9" CornerRadius="10" Background="White">
                <TextBox Text="Поиск курсов" Foreground="Black" Opacity="0.25" VerticalContentAlignment="Center" BorderThickness="0" FontSize="16" Width="276" Height="24"  />
            </Border>
            <Image Grid.Row="2" Grid.Column="12" Grid.ColumnSpan="2" HorizontalAlignment="Left" Width="22" Height="25" Source="/Icons/icons8-лупа-90.png" />



            <TextBlock Grid.Row="2" Grid.Column="0"  Grid.ColumnSpan="14" HorizontalAlignment="Center" Text="Каталог курсов" FontSize="34" FontWeight="Bold" Foreground="Black"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="14" HorizontalAlignment="Center" Foreground="#6B7280" Text="Всё, что нужно знать новичку о структуре веб-страниц и стилях." FontSize="14" FontWeight="Regular"/>
            <Button Grid.Column="2" Grid.Row="6" FontSize="14" Foreground="Black" Content="Все курсы"/>
            <Rectangle Grid.Column="2" Grid.Row="8" Fill="Black" Width="72"/>
            <Button Grid.Column="4" Grid.Row="6" FontSize="14" Foreground="Black" Content="Простой"/>
            <Button Grid.Column="6" Grid.Row="6" FontSize="14" Foreground="Black" Content="Средний"/>
            <Button Grid.Column="8" Grid.Row="6" FontSize="14" Foreground="Black" Content="Сложный"/>
        </Grid>

        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <ItemsControl x:Name="CourceList" d:ItemsSource="{d:SampleData ItemCount=20}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="10" Width="390" Height="Auto" Margin="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="190"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>


                                    <Image Grid.Row="0" Stretch="UniformToFill" VerticalAlignment="Center" Source="/Image/Book.png" >
                                        <Image.Clip>
                                            <RectangleGeometry Rect="0,0,390,400"/>
                                        </Image.Clip>
                                    </Image>

                                    <Border Grid.Row="1" Width="80" Height="20" Margin="10" HorizontalAlignment="Left" CornerRadius="5">
                                        <Border.Background>
                                            <SolidColorBrush Color="#4CAF50" Opacity="0.5"/>
                                        </Border.Background>
                                        <TextBlock Foreground="Black" Opacity="1" Text="{Binding DifficultyLevel}" VerticalAlignment="Center" TextAlignment="Center"/>
                                    </Border>

                                    <TextBlock Grid.Row="2" Margin="10" HorizontalAlignment="Left" Text="{Binding Name}" Foreground="Black" FontWeight="Bold" FontSize="24"/>


                                    <TextBlock Grid.Row="3" TextAlignment="Justify" Margin="10 0 10 10" TextWrapping="Wrap" Text ="{Binding Description}"  Foreground="#4B5563" FontWeight="Regular" FontSize="14"/>

                                    <StackPanel Margin="10" HorizontalAlignment="Center" Grid.Row="4" Orientation="Horizontal">
                                        <Image Grid.Row="3" Margin="0 0 5 0" Height="17" Width="17" Source="/Icons/icons8-часы-96.png" />
                                        <TextBlock Foreground="#4B5563" Margin="0 0 25 0" Text="4 часа" FontSize="14"/>
                                        <Image Height="17" Margin="0 0 5 0" Width="17" Source="/Icons/icons8-листы-96.png" />
                                        <TextBlock  Foreground="#4B5563" Text="12 модулей" FontSize="14"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="5" CornerRadius="8" Margin="0 0 0 20" Background="#FFA83E" Width="260" HorizontalAlignment="Center">
                                        <Button FontSize="14" Width="260" Content="Читать"/>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
