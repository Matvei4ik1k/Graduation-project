<Window x:Class="Graduation_project.View.Windows.CourseAssignment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Graduation_project.View.Windows" xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="CourseAssignment" MinHeight="900" MinWidth="1600" Width="1920" Height="1350" WindowStartupLocation="CenterScreen" WindowState="Maximized" ResizeMode="NoResize">
    <Grid Background="#EFEFEF">
        <Border Background="White" Width="1920" Height="75" VerticalAlignment="Top">
            <Grid >
                <Button x:Name="BackToCourses" Click="BackToCourses_Click" HorizontalAlignment="Left" Margin="55 0 0 0" Height="25" >
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Icons/icons8-стрелка-90.png"  Height="15" />
                        <TextBlock Text="Назад к курсам" FontWeight="Bold" Foreground="Black"  Margin="5 0 0 0" FontSize="14"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Name}"  Width="Auto" Height="Auto" Foreground="Black" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Margin="10 100 10 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="10" Background="White" CornerRadius="5">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="14"/>
                </StackPanel>
            </Border>
            <avalonEdit:TextEditor x:Name="CodeEditor" Grid.Column="1" FontSize="14" ShowLineNumbers="True" SyntaxHighlighting="HTML" Margin="0 10 0 10"/>
                <wv2:WebView2 x:Name="Preview" Grid.Column="2" Margin="10"/>
        </Grid>
    </Grid>
</Window>
