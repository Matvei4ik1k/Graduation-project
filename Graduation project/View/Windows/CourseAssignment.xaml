<Window x:Class="Graduation_project.View.Windows.CourseAssignment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Graduation_project.View.Windows" xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="CourseAssignment" MinHeight="900" MinWidth="1600" Width="1920" Height="1080" WindowStartupLocation="CenterScreen" WindowState="Maximized" ResizeMode="NoResize">
    <Grid Background="#EFEFEF">
        <Border Background="White" Width="1920" Height="75" VerticalAlignment="Top">
            <Grid >
                <Button x:Name="BackToCourses" Click="BackToCourses_Click" HorizontalAlignment="Left" Margin="55 0 0 0" Height="25" >
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Icons/icons8-стрелка-90.png"  Height="15" />
                        <TextBlock Text="Назад к курсам" FontWeight="Bold" Foreground="Black"  Margin="5 0 0 0" FontSize="14"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="CourseNameTbl" Width="Auto" Height="Auto" Foreground="Black" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Margin="10 100 10 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" VerticalAlignment="Top" Margin="10" Height="785" Background="White" CornerRadius="5">
                <StackPanel Margin="10" Orientation="Vertical">
                    <TextBlock Text="{Binding LessonTopic}" TextWrapping="Wrap" Foreground="Black" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TaskDescription}" TextWrapping="Wrap" Foreground="Black" FontSize="14"/>
                    <TextBlock Text="{Binding Instructions}" TextWrapping="Wrap" Foreground="Black" FontSize="14"/>
                </StackPanel>
            </Border>
            <Border VerticalAlignment="Bottom" Grid.Column="0" Background="White"  Margin="10" Height="140" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="0.5*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" Padding="20"  FontSize="16" FontWeight="Bold" Text="Ваш прогресс"/>
                    <TextBlock x:Name="ProgressTbl" HorizontalAlignment="Center" Grid.Row="1" FontSize="20" />
                    <ProgressBar HorizontalAlignment="Center" Grid.Row="2" Background="white" BorderBrush="Black" x:Name="ProgressBarPb" Width="300" Height="30"/>
                </Grid>
            </Border>
            <avalonEdit:TextEditor x:Name="CodeEditor" TextChanged="CodeEditor_TextChanged" Grid.Column="1" FontSize="14" ShowLineNumbers="True" SyntaxHighlighting="HTML" Margin="0 10 0 10"/>
                <wv2:WebView2 x:Name="Preview" Grid.Column="2" Margin="10"/>
        </Grid>
        <Button Content="Следующее задание" Width="180" Height="40" HorizontalAlignment="Right" Foreground="Black" VerticalAlignment="Top" Margin="20" x:Name="NextLessonBtn" Click="NextLessonBtn_Click"/>
        
    </Grid>
</Window>
