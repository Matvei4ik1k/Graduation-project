<Window x:Class="Graduation_project.View.Windows.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Graduation_project.View.Windows"
        mc:Ignorable="d"
        MinHeight="900" MinWidth="1600" Width="1920" Height="1080" Title="Authorization" WindowStartupLocation="CenterScreen" WindowState="Maximized" ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="515"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="516"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>

         <!--Левая панель--> 
        <Border Grid.RowSpan="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="0.3*"/>
                </Grid.RowDefinitions>

                <Border Grid.RowSpan="3" Opacity="0.1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E44D26" Offset="0"/>
                            <GradientStop Color="#F16529" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.1*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="0.1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="&lt;/&gt;" FontSize="80" HorizontalAlignment="Center"  Foreground="#E44D26"/>
                    <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="HTML" FontSize="32" FontWeight="Bold" Foreground="#E44D26" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Grid.Row="6" Grid.ColumnSpan="3" Text="Язык гипертекстовой разметки"  FontSize="16" Foreground="#696969" HorizontalAlignment="Center" TextAlignment="Center" />
                    <Rectangle Grid.Row="8" Grid.ColumnSpan="3" Height="2" Fill="#E44D26"  Width="240" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="10" Grid.Column="1" Text="• Доступность" FontSize="14" Foreground="#696969"/>
                    <TextBlock Grid.Row="12" Grid.Column="1" Text="• Формы и таблицы" FontSize="14" Foreground="#696969"/>
                    <TextBlock Grid.Row="14" Grid.Column="1" Text="• Структура веб-страниц" FontSize="14" Foreground="#696969"/>
                    <TextBlock Grid.Row="16" Grid.Column="1" Text="• Семантическая разметка" FontSize="14" Foreground="#696969"/>

                    <Border Grid.Row="18" Grid.Column="1" Width="auto" Background="#FFF5F2" CornerRadius="8" Padding="15"  BorderThickness="1" BorderBrush="#FFE0D6">
                        <TextBlock Text="&lt;div class=&quot;container&quot;&gt;&#x0a;  &lt;h1&gt;Заголовок&lt;/h1&gt;&#x0a;  &lt;p&gt;Абзац текста&lt;/p&gt;&#x0a;&lt;/div&gt;" 
                          FontSize="11" Foreground="#E44D26" TextAlignment="Left" FontFamily="Consolas"/>
                    </Border>

                </Grid>
            </Grid>
        </Border>

         <!--Центральная панель--> 
        <Border Grid.Column="1" Grid.RowSpan="20" Background="#2C3E50" />
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions >
                <RowDefinition Height="10"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="40" Width="652" Height="auto" Background="#34495E" CornerRadius="50" />
            <TextBlock Grid.Row="2" FontWeight="Bold" Text="Авторизация" FontSize="40" HorizontalAlignment="Center" />

            <TextBlock Grid.Row="4"  TextAlignment="Center" Text="Логин" FontSize="24"    />
            <Border Grid.Row="6" Height="50" Width="440" CornerRadius="15" Background="#46627F" >
                <TextBox Height="40" Width="415" BorderThickness="0" x:Name="LoginTb" FontSize="18" VerticalContentAlignment="Center" Text="Введите ваш логин" CaretBrush="White"/>
            </Border>

            <TextBlock  Grid.Row="8" TextAlignment="Center" Text="Пароль" FontSize="24"  />
            <Border Grid.Row="10" Height="50" Width="440" CornerRadius="15" Background="#46627F">
                <PasswordBox Height="40" Width="415" x:Name="PasswordPb" VerticalContentAlignment="Center" BorderThickness="0" FontSize="14" Password="qwerqwer" />
            </Border>

            <StackPanel Width="auto" Grid.Row="12" HorizontalAlignment="Center" Orientation="Horizontal">
                <CheckBox/>
                <TextBlock Text="Запомнить меня"  Height="30" FontSize="18"  VerticalAlignment="Center"/>
            </StackPanel>

            <Button FontSize="18" Width="150"  Content="Забыли пароль?" Grid.Row="14" />
            <Border Grid.Row="16" Background="#3498DB" Width="400" CornerRadius="10" >
                <Button  Height="60" Width="400" Content="Войти" FontSize="24" Name="LoginBtn" Click="LoginBtn_Click" />
            </Border>
            <Button Name="RegistrationBtn" Width="210" Foreground="White" Content="Создать новый аккаунт" FontSize="18" Grid.Row="18" Click="RegistrationBtn_Click" />
        </Grid>

         <!--Правая панель--> 

        <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="0.3*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.RowSpan="3" Opacity="0.1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#264DE4" Offset="0"/>
                    <GradientStop Color="#2965F1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

                <Grid Grid.Row="1" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.1*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="0.1*"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="{}{ }" FontSize="80" HorizontalAlignment="Center" Foreground="#264DE4"/>
                    <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="CSS" FontSize="32" FontWeight="Bold" Foreground="#264DE4" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Grid.Row="6" Grid.ColumnSpan="3" Text="Каскадные таблицы стилей" FontSize="16" Foreground="#696969" HorizontalAlignment="Center" TextAlignment="Center" />
                    <Rectangle Grid.Row="8" Grid.ColumnSpan="3" Height="2" Fill="#264DE4" Width="220" HorizontalAlignment="Center"/>


                    <TextBlock Grid.Row="10" Grid.Column="1" Text="• Flexbox и Grid" FontSize="14" Foreground="#696969"/>
                    <TextBlock Grid.Row="12" Grid.Column="1" Text="• Адаптивный дизайн" FontSize="14" Foreground="#696969"/>
                    <TextBlock Grid.Row="14" Grid.Column="1" Text="• Анимации и переходы" FontSize="14" Foreground="#696969"/>
                    <TextBlock Grid.Row="16" Grid.Column="1" Text="• Стилизация элементов" FontSize="14" Foreground="#696969"/>


                    <Border Grid.Row="18" Grid.Column="1" Background="#F0F5FF" CornerRadius="8" Padding="15"  BorderThickness="1" BorderBrush="#D6E4FF">
                        <TextBlock Text=".container {&#x0a;  display: flex;&#x0a;  justify-content: center;&#x0a;  background: #f5f5f5;&#x0a;}" FontSize="11" Foreground="#264DE4" TextAlignment="Left" FontFamily="Consolas" LineHeight="1.3"/>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>